# ============================================================
# Salon Microsite — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set this in Vercel dashboard for production (e.g. https://yoursalon.com)

# Optional: displayed in health check and logs
NEXT_PUBLIC_APP_VERSION=0.1.0

# ------------------------------------------------------------
# Firebase Client Configuration (public — safe to expose)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ------------------------------------------------------------
# Firebase Admin SDK (server-side only — keep secret)
# ------------------------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Paste the full private key including BEGIN/END lines, wrapped in double quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------
# Supabase (if using Supabase instead of / alongside Firebase)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# Email — Resend (https://resend.com)
# ------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
SALON_ADMIN_EMAIL=admin@yoursalon.com
NOTIFICATION_FROM_EMAIL=notifications@yoursalon.com

# ------------------------------------------------------------
# Web Push — VAPID keys
# Generate with: npx web-push generate-vapid-keys
# ------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yoursalon.com
